# UperAI · Environment Variables
# Copy this file to .env.local and fill in your keys

# ── GEMINI AI ─────────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# ── GOOGLE AUTH (NextAuth) ────────────────────────────────────────────────────
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → APIs & Services → Credentials → OAuth 2.0
# Step 3: Authorized redirect URIs → add:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://uperai.in/api/auth/callback/google        (prod)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── NEXTAUTH ──────────────────────────────────────────────────────────────────
# Generate a random secret: run → openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000   # Change to https://uperai.in in production

# ── OPTIONAL: Live Price Feed ─────────────────────────────────────────────────
NEXT_PUBLIC_POLYGON_API_KEY=

# ── APP CONFIG ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://uperai.in
NEXT_PUBLIC_APP_NAME=UperAI
