{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api-gemini/(.*)",
      "destination": "https://generativelanguage.googleapis.com/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|src/|node_modules/|@vite/|@id/|@react-refresh|favicon|assets/|index.html).*)",
      "destination": "/index.html"
    }
  ]
}
